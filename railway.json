{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "python_ai/Dockerfile"
  },
  "deploy": {
    "startCommand": "sh -c \"cd /app/python_ai && exec /app/python_ai/.venv/bin/python -m uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-8080}\"",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 120
  }
}
