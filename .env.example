# AI service cadence
PIPELINE_INTERVAL_MINUTES=60

# AI runtime selection
AI_PROVIDER=openai
AI_MODEL=gpt-4.2

# External market and model provider keys
POLYGON_API_KEY=your_polygon_api_key_here
