# AI service cadence
PIPELINE_INTERVAL_MINUTES=60
APP_LOG_LEVEL=INFO

# AI runtime selection
AI_PROVIDER=openai
AI_MODEL=gpt-4.2
# Minimum confidence required for top_3_buys in research output (0.0-1.0).
RESEARCH_MIN_BUY_CONFIDENCE=0.60
# Optional: override the default agent system prompt text.
AI_SYSTEM_PROMPT=
# Optional: local skills catalog controls for advisor tool use.
AI_SKILLS_INDEX_PATH=skills_index.json
AI_SKILLS_ROOT_PATH=skills
AI_SKILLS_PROMPT_LIMIT=15

# External market and model provider keys
POLYGON_API_KEY=your_polygon_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
SERPER_API_KEY=your_serper_api_key_here

# Pushover notifications
PUSHOVER_USER=your_pushover_user_here
PUSHOVER_TOKEN=your_pushover_token_here
PUSHOVER_URL=https://api.pushover.net/1/messages.json
